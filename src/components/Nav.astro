---
import { CATEGORIES, CATEGORY_META } from '@/data/schema';
---

<nav class="nav" aria-label="主導覽">
  <div class="inner">
    <div class="search">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </svg>
      <input
        type="search"
        id="search-input"
        placeholder="搜尋單字或中文釋義…"
        autocomplete="off"
        spellcheck="false"
      />
      <kbd>/</kbd>
    </div>

    <div class="pills" role="tablist" aria-label="分類篩選">
      <button class="pill" data-cat="all" data-active="true" type="button">
        全部 <span class="count">850</span>
      </button>
      {CATEGORIES.map((cat) => (
        <button class="pill" data-cat={cat} type="button">
          {CATEGORY_META[cat].label_zh}
          <span class="count">{CATEGORY_META[cat].expected}</span>
        </button>
      ))}
      <button class="pill pill-toggle" data-toggle="learned-only" type="button" aria-pressed="false">
        只看待學
      </button>
    </div>

    <div class="controls">
      <div class="toggle" role="group" aria-label="發音口音" title="發音口音：點卡片上的「單字 / 例句」聽英美音差異">
        <button class="seg" data-voice="en-GB" type="button" title="英式發音（en-GB）">UK</button>
        <button class="seg" data-voice="en-US" data-active="true" type="button" title="美式發音（en-US）">US</button>
      </div>
      <button class="icon-btn" id="theme-toggle" type="button" aria-label="切換亮暗主題" title="切換亮暗主題">
        <svg class="sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
        </svg>
        <svg class="moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
      <button class="cta" id="open-practice" type="button">卡片練習</button>
    </div>

    <div class="progress" aria-live="polite">
      已學 <span id="learned-count">0</span> / 850
      <div class="bar"><span id="learned-bar"></span></div>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--line);
    padding: 12px 24px;
  }
  .inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(220px, 1fr) auto auto;
    gap: 12px 16px;
    align-items: center;
  }
  @media (max-width: 900px) {
    .inner {
      grid-template-columns: 1fr;
    }
  }

  .search {
    position: relative;
    min-width: 220px;
  }
  .search svg {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--ink-faint);
  }
  .search input {
    width: 100%;
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 8px 40px 8px 38px;
    font-family: var(--sans);
    font-size: 14px;
    color: var(--ink);
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .search input:focus {
    border-color: var(--op);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--op) 18%, transparent);
  }
  .search kbd {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--sans);
    font-size: 11px;
    color: var(--ink-faint);
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 0 6px;
  }

  .pills {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .pill {
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 500;
    padding: 5px 12px;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: var(--bg-elev);
    color: var(--ink-soft);
    cursor: pointer;
    transition: all 0.15s;
    user-select: none;
    white-space: nowrap;
  }
  .pill:hover {
    background: color-mix(in srgb, var(--bg-elev) 60%, var(--bg) 40%);
    border-color: var(--ink-faint);
  }
  .pill[data-active='true'] {
    background: var(--ink);
    color: var(--bg-elev);
    border-color: var(--ink);
  }
  .pill[data-cat='operations'][data-active='true'] { background: var(--op); border-color: var(--op); }
  .pill[data-cat='general_things'][data-active='true'] { background: var(--gt); border-color: var(--gt); }
  .pill[data-cat='picturable_things'][data-active='true'] { background: var(--pt); border-color: var(--pt); }
  .pill[data-cat='qualities_general'][data-active='true'] { background: var(--qg); border-color: var(--qg); }
  .pill[data-cat='qualities_opposites'][data-active='true'] { background: var(--qo); border-color: var(--qo); }
  .pill .count {
    opacity: 0.7;
    font-variant-numeric: tabular-nums;
    margin-left: 4px;
  }
  .pill-toggle[aria-pressed='true'] {
    background: var(--ink);
    color: var(--bg-elev);
    border-color: var(--ink);
  }

  .controls {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }
  .toggle {
    display: inline-flex;
    border: 1px solid var(--line);
    border-radius: 999px;
    overflow: hidden;
    background: var(--bg-elev);
  }
  .seg {
    background: transparent;
    border: none;
    padding: 4px 10px;
    font-family: var(--sans);
    font-size: 12px;
    color: var(--ink-soft);
    cursor: pointer;
  }
  .seg[data-active='true'] {
    background: var(--ink);
    color: var(--bg-elev);
  }
  .icon-btn {
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-radius: 999px;
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--ink-soft);
    cursor: pointer;
  }
  .icon-btn:hover { color: var(--ink); }
  .icon-btn .moon { display: none; }
  [data-theme='dark'] .icon-btn .sun { display: none; }
  [data-theme='dark'] .icon-btn .moon { display: inline-block; }

  .cta {
    background: var(--op);
    color: #fff;
    border: 1px solid var(--op);
    border-radius: 999px;
    padding: 6px 16px;
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
  }
  .cta:hover { filter: brightness(0.95); }

  .progress {
    grid-column: 1 / -1;
    font-family: var(--sans);
    font-size: 12px;
    color: var(--ink-faint);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .progress .bar {
    flex: 1;
    height: 4px;
    background: var(--line);
    border-radius: 999px;
    overflow: hidden;
  }
  .progress .bar span {
    display: block;
    height: 100%;
    width: 0%;
    background: var(--op);
    transition: width 0.3s;
  }
</style>
